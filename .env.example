# MR Guardian runtime paths
#
# Copy this file to .env and adjust paths for your machine or project.
# Values from the shell environment take precedence over this file.

# Git repository to review. Use "." when running from the repository root.
MR_GUARDIAN_REPO_PATH=.

# Directory containing executable YAML policy files.
MR_GUARDIAN_POLICY_DIR=sources/yaml

# Default YAML policy used by review and inspect when --policy is omitted.
MR_GUARDIAN_POLICY_PATH=sources/yaml/unity-policy.yml

# Human guidance directory. Runtime code does not load Markdown today, but this
# keeps the project path explicit for future conversion/helper workflows.
MR_GUARDIAN_MARKDOWN_DIR=sources/markdown

# SQLite review-history database used by logs and clear-logs when --db is omitted.
MR_GUARDIAN_HISTORY_DB_PATH=.mr-guardian/history.sqlite

# Default folder for generated or example reports when a future command writes reports.
MR_GUARDIAN_REPORTS_DIR=examples/reports
